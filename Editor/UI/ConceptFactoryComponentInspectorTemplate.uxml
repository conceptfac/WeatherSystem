<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:Style src="ConceptFactoryComponentInspectorTemplate.uss" />
    <ui:VisualElement class="root">
        <ui:VisualElement name="Header" class="hero">
            <ui:VisualElement name="heroIcon" class="hero-icon" />
